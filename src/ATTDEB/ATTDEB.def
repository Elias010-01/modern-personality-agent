    CONTROL                @3
    DISABLE                @4
    ENABLE                 @5
    ENUMDFONTS             @6
    ENUMOBJ                @7
    OUTPUT                 @8
    PIXEL                  @9
    REALIZEOBJECT          @10
    STRBLT                 @11
    SCANLR                 @12
    DEVICEMODE             @13
    INQUIRE                @101
    SETCURSOR              @102
    MOVECURSOR             @103
    CHECKCURSOR            @104
