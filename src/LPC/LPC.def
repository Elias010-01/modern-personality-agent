; MOUSE.DEF - module definition para Windows 1.x
; AUTO-GENERATED desde LPC.DRV (NE entry/relocation tables)

LIBRARY     MOUSE
DESCRIPTION 'the Lite-Pen Company - Lightpen'
EXETYPE     WINDOWS
STUB        'WINSTUB.EXE'

CODE        PRELOAD FIXED
DATA        PRELOAD FIXED SINGLE

IMPORTS
    SYSTEM.CREATESYSTEMTIMER
    SYSTEM.DISABLESYSTEMTIMERS
    SYSTEM.ENABLESYSTEMTIMERS
    SYSTEM.KILLSYSTEMTIMER

EXPORTS
    INQUIRE                @1
    ENABLE                 @2
    DISABLE                @3
